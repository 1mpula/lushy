            "id": "get-accepted",
            "name": "GET Accepted Bookings",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                250,
                600
            ]
        },
        {
            "parameters": {
                "fieldToSplitOut": "={{ $json }}",
                "options": {}
            },
            "id": "split-bookings",
            "name": "Split Bookings",
            "type": "n8n-nodes-base.splitOut",
            "typeVersion": 1,
            "position": [
                500,
                600
            ]
        },
        {
            "parameters": {
                "jsCode": "// Calculate hours until appointment\nconst booking = $input.item.json;\nconst now = new Date();\n\n// Combine date and time\nconst appointmentDateTime = new Date(`${booking.booking_date}T${booking.booking_time}`);\nconst hoursUntil = (appointmentDateTime - now) / (1000 * 60 * 60);\n\n// Determine reminder type\nlet reminderType = null;\nif (hoursUntil >= 23 && hoursUntil <= 25) {\n  reminderType = '24hr';\n} else if (hoursUntil >= 2.5 && hoursUntil <= 3.5) {\n  reminderType = '3hr';\n}\n\nreturn {\n  ...booking,\n  hoursUntil: Math.round(hoursUntil),\n  reminderType: reminderType,\n  shouldRemind: reminderType !== null\n};"
            },
            "id": "calc-time",
            "name": "Calculate Time Until",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                750,
                600
            ]
        },
        {
            "parameters": {
                "conditions": {
                    "options": {
                        "caseSensitive": true,
                        "leftValue": "",
                        "typeValidation": "loose"
                    },
                    "conditions": [
                        {
                            "id": "cond1",
                            "leftValue": "={{ $json.shouldRemind }}",
                            "rightValue": true,
                            "operator": {
                                "type": "boolean",
                                "operation": "equals"
                            }
                        }
                    ],
                    "combinator": "and"
                },
                "options": {}
            },
            "id": "should-remind",
            "name": "Should Send Reminder?",
            "type": "n8n-nodes-base.if",
            "typeVersion": 2.2,
            "position": [
                1000,
                600
            ]
        },
        {
            "parameters": {
                "assignments": {
                    "assignments": [
                        {
                            "id": "1",
                            "name": "clientMessage",
                            "value": "=⏰ Reminder: Your {{ $json.service_name }} appointment with {{ $json.professional_name }} is {{ $json.reminderType === '24hr' ? 'tomorrow' : 'in 3 hours' }} at {{ $json.booking_time }}!",
                            "type": "string"
                        },
                        {
                            "id": "2",
                            "name": "proMessage",
                            "value": "=⏰ Reminder: {{ $json.service_name }} appointment with {{ $json.client_name }} is {{ $json.reminderType === '24hr' ? 'tomorrow' : 'in 3 hours' }} at {{ $json.booking_time }}!",
                            "type": "string"
                        },
                        {
                            "id": "3",
                            "name": "clientPhone",
                            "value": "={{ $json.client_phone }}",
                            "type": "string"
                        },
                        {
                            "id": "4",
                            "name": "proPhone",
                            "value": "={{ $json.professional_phone }}",
                            "type": "string"
                        },
                        {
                            "id": "5",
                            "name": "bookingId",
                            "value": "={{ $json.id }}",
                            "type": "string"
                        }
                    ]
                },
                "options": {}
            },
            "id": "format-reminder",
            "name": "Format Reminders",
            "type": "n8n-nodes-base.set",
            "typeVersion": 3.4,
            "position": [
                1250,
                500
            ]
        },
        {
            "parameters": {},
            "id": "noop",
            "name": "No Reminder Needed",
            "type": "n8n-nodes-base.noOp",
            "typeVersion": 1,
            "position": [
                1250,
                700
            ]
        }
    ],
